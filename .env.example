# GitHub API Configuration
# Create a personal access token at: https://github.com/settings/tokens
# The token needs read access to your repository
GITHUB_TOKEN=your_github_token_here

# GitHub Repository Configuration
GITHUB_OWNER=your_username
GITHUB_REPO=your_blog_repo

# Path to your markdown files within the repository
# Default is 'posts' if not specified
POSTS_PATH=posts

# Attachment
ATTACHMENT_PATH=attachment

# LULU
LULU_COOKIE=your_lulu_cookie
LULU_TOKEN=your_lulu_token

# AI
AI_TOKEN=your_ai_token
AI_BASE_URL=https://your-ai-base-url/v1

# SITE_URL
SITE_URL=http://localhost:3000

# UPSTASH REDIS
UPSTASH_REDIS_REST_URL=https://your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
